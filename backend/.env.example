DB_USERNAME=avnadmin
DB_PASSWORD=replace-with-db-password

# SMTP (required for forgot-password OTP emails)
# For Gmail, use a dedicated App Password (not your normal Gmail password).
MAIL_USERNAME=your-sender@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# Auth security
APP_AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
APP_AUTH_TOKEN_TTL_MINUTES=720
APP_AUTH_PASSWORD_MIN_LENGTH=8

# Password reset controls
APP_AUTH_RESET_OTP_TTL_MINUTES=10
APP_AUTH_RESET_MAX_VERIFY_ATTEMPTS=5
APP_AUTH_RESET_REQUEST_WINDOW_MINUTES=15
APP_AUTH_RESET_MAX_REQUESTS_PER_WINDOW=3
APP_AUTH_RESET_MIN_SECONDS_BETWEEN_REQUESTS=30

# Bootstrap admin
BOOTSTRAP_ADMIN_EMAIL=admin@retailstore.com
BOOTSTRAP_ADMIN_NAME=Retail Admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
